{
  "name": "clikko-local",
  "version": "1.3.2",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npm --prefix release/clikko-backend run dev",
    "backend": "npm --prefix release/clikko-backend run dev",
    "android:init": "npx cap init clikko-local com.clikko.local --web-dir=public",
    "android:add": "npx cap add android",
    "android:copy": "npx cap copy android",
    "android:open": "npx cap open android",
    "android:build": "npm run android:copy && npx cap open android"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "dotenv": "^16.3.1",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0"
  }
}
